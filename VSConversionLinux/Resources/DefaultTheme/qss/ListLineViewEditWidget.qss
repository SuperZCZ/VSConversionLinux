QLineEdit#ListLineEdit{
    max-height: 18px;
    min-height: 18px;
}

QPushButton#AddItemBtn{
    max-width: 20px;
    min-width: 20px;
    max-height: 20px;
    min-height: 20px;
    outline: none;
    border: none;
}
QPushButton#AddItemBtn:enabled{
    image: url(:/images/list_add.png);
}
QPushButton#AddItemBtn:disabled{
    image: url(:/images/list_add_gray.png);
}
QPushButton#AddItemBtn:!disabled:hover{
    background-color: #D1EAFF;
}

QPushButton#RemoveItemBtn{
    max-width: 20px;
    min-width: 20px;
    max-height: 20px;
    min-height: 20px;
    outline: none;
    border: none;
}
QPushButton#RemoveItemBtn:enabled{
    image: url(:/images/list_del.png);
}
QPushButton#RemoveItemBtn:disabled{
    image: url(:/images/list_del_gray.png);
}
QPushButton#RemoveItemBtn:!disabled:hover{
    background-color: #D1EAFF;
}


QPushButton#EditItemBtn{
    max-width: 20px;
    min-width: 20px;
    max-height: 20px;
    min-height: 20px;
    outline: none;
    border: none;
}
QPushButton#EditItemBtn:enabled{
    image: url(:/images/edit.png);
}
QPushButton#EditItemBtn:disabled{
    image: url(:/images/edit_gray.png);
}
QPushButton#EditItemBtn:!disabled:hover{
    background-color: #D1EAFF;
}

QPushButton#UpItemBtn{
    max-width: 20px;
    min-width: 20px;
    max-height: 20px;
    min-height: 20px;
    outline: none;
    border: none;
}
QPushButton#UpItemBtn:enabled{
    image: url(:/images/up.png);
}
QPushButton#UpItemBtn:disabled{
    image: url(:/images/up_gray.png);
}
QPushButton#UpItemBtn:!disabled:hover{
    background-color: #D1EAFF;
}

QPushButton#DownItemBtn{
    max-width: 20px;
    min-width: 20px;
    max-height: 20px;
    min-height: 20px;
    outline: none;
    border: none;
}
QPushButton#DownItemBtn:enabled{
    image: url(:/images/down.png);
}
QPushButton#DownItemBtn:disabled{
    image: url(:/images/down_gray.png);
}
QPushButton#DownItemBtn:!disabled:hover{
    background-color: #D1EAFF;
