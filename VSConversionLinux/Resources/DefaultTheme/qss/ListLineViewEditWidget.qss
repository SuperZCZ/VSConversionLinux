/*QWidget#ListLineViewEditWidget{
    border: 1px solid red;
}*/

QListView#ListEditView{
	border: 1px solid gray;
	background-color: transparent;
}


QListView#ListEditView::item:!disabled{
	border-left: 0px;
	border-top: 0px;
	border-bottom: 1px solid gray;
	border-right: 0px;
	background-color: transparent;
    color: black;
}
QListView#ListEditView::item:!disabled:hover{
	background-color: #E5F3FF;
}
QListView#ListEditView::item:!disabled:selected{
	border-top: 0px;
	border-left: 0px;
	border-right: 0px;
	border-bottom: 1px solid gray;
	background-color: #CDE8FF;
}
QListView#ListEditView::item:!disabled:selected:hover{
	background-color: #E5F3FF;
}

QListView#ListEditView::item:disabled{
	border-left: 0px;
	border-top: 0px;
	border-bottom: 1px solid #BFBFBF;
	border-right: 0px;
	background-color: transparent;
    color: #BFBFBF;

}
QListView#ListEditView::item:disabled:selected{
	border-top: 0px;
	border-left: 0px;
	border-right: 0px;
	border-bottom: 1px solid #BFBFBF;
	background-color: #F0F0F0;
}

QLabel#ListItemDisplayStyleLabel{
    min-height: 20px;
    max-height: 20px;
    border: none;
    background-color: transparent;
}

QLineEdit#TextItemLineEditor{
    border: none;
    padding: 0px 5px 0px 5px;
    background-color: #EFF0F1;
}

QWidget#PathItemEditWidget{
    border: none;
    background-color: #EFF0F1;
}

QFrame#PathItemEditWidgetLineFrame{
    max-width: 1px;
    min-width: 1px;
    margin: 1px 0px 1px 0px;
    border: none;
    background-color: #BFBFBF;
}

QLineEdit#PathItemLineEditor{
    margin-left: 5px;
    border: none;
    background-color: #EFF0F1;
}

QPushButton#PathItemBrowseBtn{
    border: none;

}

QPushButton#PathItemBrowseBtn{
    max-width: 18px;
    min-width: 18px;
    max-height: 18px;
    min-height: 18px;
    outline: none;
    border: none;
}
QPushButton#PathItemBrowseBtn:enabled{
    image: url(:/images/open_file.png);
}
QPushButton#PathItemBrowseBtn:disabled{
    image: url(:/images/open_file_gray.png);
}
QPushButton#PathItemBrowseBtn:!disabled:hover{
    image: url(:/images/open_file_hover.png);
    background-color: #E5F3FF;
}

QPushButton#PathItemBrowseBtn:!disabled:pressed{
    background-color: #CDE8FF;
}